<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OSM Update Utility</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body {
                font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
                background-color: #f4f5f7;
                color: #333;
                margin: 0;
                padding: 20px;
                font-size: 14px;
            }

            .container {
                max-width: 1000px;
                margin: 0 auto;
                background: #fff;
                padding: 20px;
                border: 1px solid #d1d5db;
            }

            h1, h2, h3 {
                font-size: 1.1rem;
                font-weight: 600;
                margin-top: 0;
                margin-bottom: 15px;
                padding-bottom: 8px;
                border-bottom: 1px solid #e5e7eb;
                color: #111;
            }

            .nav {
                margin-bottom: 20px;
                border-bottom: 1px solid #d1d5db;
                display: flex;
                align-items: center;
            }

                .nav a {
                    display: inline-block;
                    margin-right: 20px;
                    padding: 8px 0;
                    text-decoration: none;
                    color: #4b5563;
                    font-weight: 500;
                }

                    .nav a.active {
                        color: #2563eb;
                        border-bottom: 2px solid #2563eb;
                    }

            .btn {
                display: inline-block;
                padding: 6px 12px;
                font-size: 13px;
                border: 1px solid transparent;
                cursor: pointer;
                text-decoration: none;
                border-radius: 2px;
                font-weight: 500;
            }

            .btn-primary {
                background-color: #2563eb;
                color: white;
                border-color: #2563eb;
            }

                .btn-primary:hover {
                    background-color: #1d4ed8;
                    color: white;
                }

            .btn-secondary {
                background-color: #6b7280;
                color: white;
                border-color: #6b7280;
            }

                .btn-secondary:hover {
                    background-color: #4b5563;
                    color: white;
                }

            .btn-danger {
                background-color: #dc2626;
                color: white;
                border-color: #dc2626;
            }

                .btn-danger:hover {
                    background-color: #b91c1c;
                    color: white;
                }

            .btn-sm {
                padding: 4px 8px;
                font-size: 12px;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 20px;
                font-size: 13px;
            }

            th, td {
                border: 1px solid #d1d5db;
                padding: 8px;
                text-align: left;
            }

            th {
                background-color: #f9fafb;
                font-weight: 600;
            }

            .form-group {
                margin-bottom: 15px;
            }

                .form-group label {
                    display: block;
                    margin-bottom: 5px;
                    font-weight: 500;
                    color: #374151;
                }

            input[type="text"], input[type="number"], select {
                padding: 6px 8px;
                border: 1px solid #d1d5db;
                border-radius: 2px;
                font-size: 13px;
                width: 100%;
                box-sizing: border-box;
            }

                input[type="text"]:focus, select:focus {
                    outline: none;
                    border-color: #2563eb;
                }

            .alert {
                padding: 10px 15px;
                margin-bottom: 15px;
                border: 1px solid transparent;
                border-radius: 2px;
                font-size: 13px;
            }

            .alert-warning {
                background-color: #fef3c7;
                border-color: #fcd34d;
                color: #92400e;
            }

            .alert-info {
                background-color: #dbeafe;
                border-color: #93c5fd;
                color: #1e40af;
            }

            .alert-danger {
                background-color: #fef2f2;
                border-color: #fca5a5;
                color: #991b1b;
            }

            .log-box {
                background: #f9fafb;
                border: 1px solid #d1d5db;
                padding: 10px;
                font-family: "Consolas", "Monaco", monospace;
                font-size: 12px;
                max-height: 250px;
                overflow-y: auto;
                white-space: pre-wrap;
                color: #374151;
            }

            .row {
                display: flex;
                gap: 20px;
            }

            .col {
                flex: 1;
            }

            form {
                display: inline;
            }
    </style>
</head>
<body>
    <div class="container">
        <div style="margin-bottom: 15px;">
            <h1 style="border: none; margin: 0; font-size: 1.3rem;">OSM Update Utility</h1>
        </div>
        <div class="nav">
            <a href="/" class="@(ViewData["ActivePage"]?.ToString() == "Index" ? "active" : "")">Главная</a>
            <a href="/Settings" class="@(ViewData["ActivePage"]?.ToString() == "Settings" ? "active" : "")">Настройки</a>
            <span class="navbar-text ms-auto me-3">@User.Identity?.Name</span>
            <a class="nav-link" href="/Logout" style="color: #dc2626;">Выйти</a>
        </div>

        @RenderBody()
    </div>
</body>
</html>